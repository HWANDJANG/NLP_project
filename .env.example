# Copy to .env and fill in.
# Paste the raw "Cookie:" header value from a logged-in browser session.
# In Chrome DevTools -> Network -> any ssodam request -> Request Headers -> Cookie.
SSODAM_COOKIE=

# Optional: override the default User-Agent.
SSODAM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Seconds to sleep between requests. Be polite.
SSODAM_REQUEST_DELAY=1.5

# SSL: leave unset / "true" by default. If you see CERTIFICATE_VERIFY_FAILED
# even after truststore is installed, set this to "false" to skip verification.
# SSODAM_SSL_VERIFY=true
